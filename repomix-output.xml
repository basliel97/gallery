      <div className="rounded-2xl border border-white/20 bg-white/40 p-6 shadow-xl backdrop-blur-md dark:border-white/10 dark:bg-zinc-900/40 sm:p-8">
        <form onSubmit={handleSubmit} className="space-y-5">
